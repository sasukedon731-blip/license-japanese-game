rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return myRole() == "admin";
    }

    function isCompanyAdmin() {
      return myRole() == "company_admin";
    }

    function myCompanyCode() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc(request.auth.uid).data.companyCode
        : null;
    }

    function protectedUserKeys() {
      return [
        "billing",
        "role",
        "companyCode",
        "companyName",
        "accountType",
        "createdAt",
        "uid"
      ];
    }

    function isSameCompanyUser(uid) {
      return isCompanyAdmin() &&
        exists(/databases/$(database)/documents/users/$(uid)) &&
        myCompanyCode() != null &&
        userDoc(uid).data.companyCode == myCompanyCode();
    }

    match /users/{uid} {
      allow get: if signedIn() && (
        request.auth.uid == uid ||
        isAdmin() ||
        isSameCompanyUser(uid)
      );

      allow list: if signedIn() && (
        isAdmin() ||
        (isCompanyAdmin() && resource.data.companyCode == myCompanyCode())
      );

      allow create: if signedIn() &&
        request.auth.uid == uid &&
        request.resource.data.uid == uid &&
        request.resource.data.role == "user" &&
        (
          (
            request.resource.data.accountType == "personal" &&
            request.resource.data.billing.accountType == "personal" &&
            request.resource.data.billing.method == "trial" &&
            request.resource.data.billing.status == "trialing" &&
            request.resource.data.billing.currentPlan == "trial"
          ) ||
          (
            request.resource.data.accountType == "company" &&
            request.resource.data.billing.accountType == "company" &&
            request.resource.data.billing.method == "company" &&
            request.resource.data.billing.status == "active" &&
            request.resource.data.billing.currentPlan == "7" &&
            request.resource.data.companyCode is string &&
            exists(/databases/$(database)/documents/companies/$(request.resource.data.companyCode)) &&
            get(/databases/$(database)/documents/companies/$(request.resource.data.companyCode)).data.active != false
          )
        );

      allow update: if signedIn() &&
        request.auth.uid == uid &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedUserKeys()) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["uid", "updatedAt"]) &&
            !resource.data.keys().hasAny(["uid"]) &&
            request.resource.data.uid == request.auth.uid
          )
        );

      allow delete: if isAdmin();
    }

    match /users/{uid}/progress/{quizType} {
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (
          isSameCompanyUser(uid)
        )
      );
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/results/{resultId} {
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (
          isSameCompanyUser(uid)
        )
      );
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /companies/{companyCode} {
      allow get: if signedIn() && (
        isAdmin() ||
        (isCompanyAdmin() && companyCode == myCompanyCode()) ||
        resource.data.active != false
      );
      allow list: if signedIn() && isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /paymentOrders/{orderId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
